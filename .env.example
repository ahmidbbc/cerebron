APP_ENV=local
APP_MODE=test
HTTP_ADDRESS=:8080
HTTP_SHUTDOWN_TIMEOUT=10s
OBSERVED_ENVS=
DEFAULT_POLL_INTERVAL=1m

DATADOG_ENABLED=false
DATADOG_BASE_URL=https://api.datadoghq.com
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_MONITOR_TAGS=
DATADOG_ERROR_TRACKING_ENABLED=false
DATADOG_ERROR_TRACKING_BASE_URL=https://api.datadoghq.com
DATADOG_ERROR_TRACKING_TRACK=trace
DATADOG_ERROR_TRACKING_QUERY=

# Elasticsearch / OpenSearch
# ELASTIC_TOKEN is sent as-is in the Authorization header.
# Examples:
# - ApiKey <base64_api_key>
# - Bearer <token>
# Leave it empty when the cluster is reachable without HTTP auth.
# For local development behind a tunnel or kubectl port-forward, use:
# ELASTIC_BASE_URL=http://host.docker.internal:9200
ELASTIC_ENABLED=false
ELASTIC_BASE_URL=
ELASTIC_TOKEN=
ELASTIC_INDEX_PATTERN=*
ELASTIC_ENVIRONMENT_FIELDS=k8s-namespace,service.environment,environment,env,labels.env

GERRIT_ENABLED=false
GERRIT_BASE_URL=
GERRIT_TOKEN=

GITHUB_ENABLED=false
GITHUB_BASE_URL=https://api.github.com
GITHUB_TOKEN=

SLACK_ENABLED=false
SLACK_BASE_URL=https://slack.com/api
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/monitoring_agent?sslmode=disable
REDIS_ADDR=localhost:6379
